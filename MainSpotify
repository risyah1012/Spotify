public class MainSpotify {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Playlist myPlaylist = new Playlist();
        int pilihan;
        
        System.out.println("==================================================");
        System.out.println("                 SPOTIFY PLAYLIST                 ");
        System.out.println("==================================================");
        
        // Data awal
        myPlaylist.addSong("Hati-Hati di Jalan", "Tulus");
        myPlaylist.addSong("Sial", "Mahalini");
        myPlaylist.addSong("Glimpse of Us", "Joji");
        myPlaylist.addSong("Die With A Smile", "Bruno Mars & Lady Gaga");
        
        do {
            System.out.println("\n=== MENU UTAMA ===");
            System.out.println(" 1. Tambah Lagu ");
            System.out.println(" 2. Putar Lagu Saat Ini");
            System.out.println(" 3. Lagu Berikutnya (Next)");
            System.out.println(" 4. Lagu Sebelumnya (Prev)");
            System.out.println(" 5. Tampilkan Playlist");
            System.out.println(" 6. Sisipkan Lagu ");
            System.out.println(" 7. Hapus Lagu");
            System.out.println(" 0. Keluar");
            System.out.print("\nPilih menu: ");
            
            pilihan = scanner.nextInt();
            scanner.nextLine();
            
            System.out.println();
            
            switch (pilihan) {
                case 1:
                    // Tambah di akhir
                    System.out.print("Masukkan judul lagu: ");
                    String title = scanner.nextLine();
                    System.out.print("Masukkan nama artis: ");
                    String artist = scanner.nextLine();
                    myPlaylist.addSongWithMessage(title, artist);
                    break;
                    
                case 2:
                    // Putar lagu saat ini
                    myPlaylist.playCurrent();
                    break;
                    
                case 3:
                    // Next
                    myPlaylist.nextTrack();
                    break;
                    
                case 4:
                    // Prev
                    myPlaylist.prevTrack();
                    break;
                    
                case 5:
                    // Tampilkan playlist
                    myPlaylist.displayPlaylist();
                    break;
                    
                case 6:
                    // SISIPKAN LAGU 
                    System.out.print("Masukkan judul lagu: ");
                    String titleInsert = scanner.nextLine();
                    System.out.print("Masukkan nama artis: ");
                    String artistInsert = scanner.nextLine();
                    System.out.print("Masukkan posisi sisip (1-" + (myPlaylist.getSize() + 1) + "): ");
                    int position = scanner.nextInt();
                    scanner.nextLine();
                    myPlaylist.insertSongAt(titleInsert, artistInsert, position);
                    break;
                    
                case 7:
                    // HAPUS LAGU 
                    if (myPlaylist.getSize() == 0) {
                        System.out.println("[INFO] Playlist kosong! Tidak ada lagu untuk dihapus.");
                        break;
                    }
                    myPlaylist.displayPlaylist();
                    System.out.print("Masukkan nomor lagu yang akan dihapus (1-" + myPlaylist.getSize() + "): ");
                    int deletePos = scanner.nextInt();
                    scanner.nextLine();
                    myPlaylist.deleteSong(deletePos);
                    break;
                    
                case 0:
                    System.out.println("Thanks Telah Using Program From Kelompok 2 Yang Very Cool Ini..!!");
                    System.out.println("Rawrrrr....");
                    break;
                    
                default:
                    System.out.println("[GAGAL] Pilihan tidak valid!");
            }
            
        } while (pilihan != 0);
        
        scanner.close();
    }
}
